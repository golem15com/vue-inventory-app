# vue-starter-app environment template.
#
# Copy to `.env` and adjust. PLACEHOLDERS ONLY — never commit real secrets.
# All NUXT_PUBLIC_* keys are non-secret (they ship to the browser); they override
# the dev defaults declared in nuxt.config.ts runtimeConfig.public.
#
# In dev the app proxies these backend routes to http://localhost:8000 (see the
# nitro.devProxy + vite.server.proxy blocks in nuxt.config.ts), so the defaults
# below normally need no change for local development against a running backend.

# --- Public runtime config (non-secret, browser-exposed) ---------------------
# Base origin of the WinterCMS backend.
NUXT_PUBLIC_API_BASE=http://localhost:8000
# Golem15.User JWT auth API.
NUXT_PUBLIC_USER_API_BASE=http://localhost:8000/_user/api/v1
# Golem15.Journal blog read API.
NUXT_PUBLIC_JOURNAL_API_BASE=http://localhost:8000/_journal/api/v1
# Centrifugo websocket URL. Leave empty to gracefully disable realtime.
# Dev value when Centrifugo is running: ws://localhost:8000/connection/websocket
NUXT_PUBLIC_CENTRIFUGO_WS_URL=
# Public site URL (used by @nuxtjs/seo for canonical/sitemap/OG).
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Playwright E2E (demo credentials only — NOT real secrets) ---------------
# A seeded backend test user for the login/auth smoke specs.
E2E_EMAIL=demo@example.com
E2E_PASSWORD=changeme
# Frontend URL the E2E suite targets.
E2E_FRONTEND_URL=http://localhost:3000
