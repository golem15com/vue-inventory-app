# vue-inventory-app (whereiput.it) — environment template.
#
# Copy to `.env` and adjust. PLACEHOLDERS ONLY — never commit real secrets.
# All NUXT_PUBLIC_* keys are non-secret (they ship to the browser) and override
# the dev defaults declared in nuxt.config.ts runtimeConfig.public. Nuxt maps
# each NUXT_PUBLIC_<KEY> onto its public.<key> automatically at runtime.

# --- Backend wiring (dev) ----------------------------------------------------
# The app addresses the backend with SAME-ORIGIN relative paths
# (/_user/api, /_inventory/api, /api/realtime, /storage), so there is no
# cross-origin request and no CORS — in dev OR prod. In dev those paths are
# proxied to NUXT_DEV_BACKEND_ORIGIN; in prod the app is served same-origin with
# the backend. This ALSO becomes the SSR internalApiOrigin in dev (see
# nuxt.config.ts), so a hard reload validates your local auth_token against THIS
# backend — not prod.
#
# Point this at your running WinterCMS Inventory backend. NB: nuxt.config.ts
# defaults to :8000, but the Inventory backend's `php artisan serve` runs on
# :8421 — set it explicitly:
NUXT_DEV_BACKEND_ORIGIN=http://localhost:8421

# Override the public API bases ONLY if the backend lives on a genuinely
# different origin than the app — in which case that backend MUST send CORS
# headers for the app origin (config/cors.php `paths`). Leave these unset for the
# same-origin / dev-proxy default.
# NUXT_PUBLIC_API_BASE=
# NUXT_PUBLIC_USER_API_BASE=
# NUXT_PUBLIC_INVENTORY_API_BASE=
# NUXT_PUBLIC_JOURNAL_API_BASE=

# --- MCP integration (Settings → Integrations) -------------------------------
# The Inventory MCP server is SELF-HOSTED — there is no hosted SaaS. The
# Integrations tab shows a `curl | bash` installer one-liner and the manual
# Claude/Codex snippets composed from these. The nuxt.config.ts defaults are
# `https://mcp.example.com` PLACEHOLDERS — set both to your own MCP host so the
# install command is correct for your deployment. See the `inventory-mcp`
# submodule for how to deploy one.
# NUXT_PUBLIC_MCP_INSTALL_URL=https://mcp.your-host.example
# NUXT_PUBLIC_MCP_INSTALL_COMMAND=curl -fsSL https://mcp.your-host.example | bash

# --- Realtime (Centrifugo, optional) -----------------------------------------
# WS endpoint the browser connects to. Leave EMPTY to gracefully disable realtime
# (the app boots/builds/tests fine; realtime just no-ops).
# This is a DIRECT cross-origin socket (NOT proxied). To enable realtime:
#   1. Set this to your Centrifugo connection endpoint, e.g.
#        ws://localhost:8787/connection/websocket
#   2. Add the app origin (e.g. http://localhost:3118) to Centrifugo's
#        client.allowed_origins  (else the WS handshake is rejected, silently).
#   3. On the BACKEND set, to match your Centrifugo config:
#        CENTRIFUGO_SECRET  = Centrifugo client.token.hmac_secret_key
#        CENTRIFUGO_API_KEY = Centrifugo http_api.key
#        CENTRIFUGO_API_URL = http://<centrifugo-host>:<port>/api
#      The backend mints a per-user connection JWT at GET /api/realtime/token
#      (jwt.auth-gated — the user must be logged in).
NUXT_PUBLIC_CENTRIFUGO_WS_URL=

# --- SEO ---------------------------------------------------------------------
# Public site URL (used by @nuxtjs/seo for canonical/sitemap/OG). Defaults to
# https://whereiput.it in nuxt.config.ts; override per deployment.
NUXT_PUBLIC_SITE_URL=http://localhost:3118

# --- Playwright E2E (demo credentials only — NOT real secrets) ---------------
# Seeded backend test user for the login + inventory specs (backend-gated specs
# skip, not fail, when these / the backend are absent).
E2E_EMAIL=demo@example.com
E2E_PASSWORD=changeme
# Backend the E2E seed helper (tinker) targets, and the frontend URL under test.
E2E_BACKEND_URL=http://localhost:8421
E2E_FRONTEND_URL=http://localhost:3118
# Set to 1 to exercise the LIVE realtime path (otherwise realtime asserts graceful-degrade).
# E2E_CENTRIFUGO=1
