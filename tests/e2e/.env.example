# Playwright E2E env contract — PLACEHOLDERS ONLY.
#
# Copy this file to tests/e2e/.env.local (gitignored) and fill in REAL values for a
# live run. NEVER commit real credentials (T-17-12) — .env.local and tests/e2e/.auth/
# are gitignored. Backend-gated specs (login.spec.ts, blog.spec.ts) and auth.setup.ts
# SKIP when these are unset, so CI without a backend passes the always-green baseline.

# Seeded backend test user (auth.setup.ts + login.spec.ts). Create via the
# helpers/runTinker.ts seeder or by hand in the WinterCMS backend.
E2E_EMAIL=
E2E_PASSWORD=

# Where the Nuxt app is served (Playwright baseURL + webServer url).
E2E_FRONTEND_URL=http://localhost:3118

# WinterCMS backend (blog.spec.ts reachability gate + seed helper).
E2E_BACKEND_URL=http://localhost:8000

# Optional: path to a running WinterCMS checkout for helpers/runTinker.ts seeding.
# Defaults to the inventory superproject root (../../../.. from this file).
# BACKEND_DIR=/path/to/wintercms/checkout
